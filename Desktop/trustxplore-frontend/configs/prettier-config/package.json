{
  "name": "@repo/prettier-config",
  "version": "1.0.0",
  "private": true,
  "description": "Prettier config",
  "author": "Nisharg Shah <nishargshah3101@gmail.com>",
  "type": "module",
  "exports": {
    "./base": "./src/prettier-base.config.js",
    "./tailwind": "./src/prettier-tailwind.config.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "format": "prettier . --check --log-level silent --ignore-path ../../.gitignore",
    "format:fix": "prettier . --write --log-level silent --ignore-path ../../.gitignore",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
